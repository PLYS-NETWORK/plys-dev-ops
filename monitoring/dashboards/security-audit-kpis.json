          "type": "line",
          "title": "Register / verify_email funnel",
          "description": "",
          "config": {
            "show_legends": true,
            "legends_position": null,
            "show_symbol": true,
            "show_gridlines": true
          },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT histogram(_timestamp, '1 hour') AS ts,\n  count(CASE WHEN action = 'register' AND outcome = 'success' THEN 1 END) AS registrations,\n  count(CASE WHEN action = 'verify_email' AND outcome = 'success' THEN 1 END) AS verifications\nFROM \"identity-service\"\nWHERE log_type = 'audit' AND action IN ('register', 'verify_email')\nGROUP BY ts\nORDER BY ts ASC",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
