            "show_legends": true,
            "legends_position": null,
            "show_symbol": false,
            "show_gridlines": true
          },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT _timestamp, service, message, log_type, severity_text\nFROM \"default\"\nWHERE level = 'error' OR severity_text = 'ERROR' OR log_type IN ('error', 'unhandled')\nORDER BY _timestamp DESC\nLIMIT 50",
