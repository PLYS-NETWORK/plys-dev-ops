            "show_symbol": true,
            "show_gridlines": true
          },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT histogram(_timestamp, '1 hour') AS ts,\n  count(CASE WHEN action = 'withdraw_create' THEN 1 END) AS creates,\n  count(CASE WHEN action = 'withdraw_cancel' THEN 1 END) AS cancels\nFROM \"finance-service\"\nWHERE log_type = 'audit' AND action IN ('withdraw_create', 'withdraw_cancel')\nGROUP BY ts\nORDER BY ts ASC",
