        {
          "id": "platform_p95_latency",
          "type": "table",
          "title": "p95 latency by path (top 10)",
          "description": "",
          "config": {
            "show_legends": true,
            "legends_position": null,
            "show_symbol": false,
            "show_gridlines": true
          },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT path,\n  approx_percentile_cont(duration_ms, 0.95) AS p95_ms,\n  count(*) AS requests\nFROM \"api-gateway\"\nWHERE log_type = 'access' AND duration_ms IS NOT NULL AND path IS NOT NULL\nGROUP BY path\nORDER BY p95_ms DESC\nLIMIT 10",
              "vrlFunctionQuery": "",
              "customQuery": true,
              "fields": {
                "stream": "api-gateway",
                "stream_type": "logs",
