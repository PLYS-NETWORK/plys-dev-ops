            "show_gridlines": true
          },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT service,\n  count(CASE WHEN status_code BETWEEN 400 AND 499 THEN 1 END) AS client_errors,\n  count(CASE WHEN status_code >= 500 THEN 1 END) AS server_errors\nFROM \"default\"\nWHERE log_type = 'access' AND status_code >= 400\nGROUP BY service\nORDER BY server_errors DESC",
              "vrlFunctionQuery": "",
              "customQuery": true,
