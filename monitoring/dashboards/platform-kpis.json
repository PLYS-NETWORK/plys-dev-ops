          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT histogram(_timestamp, '5 minute') AS ts,\n  100.0 * count(CASE WHEN status_code >= 500 THEN 1 END) / count(*) AS error_rate_pct\nFROM \"api-gateway\"\nWHERE log_type = 'access'\nGROUP BY ts\nORDER BY ts ASC",
