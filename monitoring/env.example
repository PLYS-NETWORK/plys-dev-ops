# Template for monitoring deploy .env (rendered by scripts/render-monitoring-env.mjs).
# Password is injected from GitHub secret OPENOBSERVE_ROOT_PASSWORD — do not commit real values.

ZO_ROOT_USER_EMAIL=huuphuc9410@gmail.com
ZO_ROOT_USER_PASSWORD=

OPENOBSERVE_AUTH_B64=

# Comma-separated OpenObserve org slugs (collector routes logs/traces/metrics to each).
OPENOBSERVE_ORGS=internal-hub-api,internal-hub-fe,ployos-fe,lonaos-fe

DEPLOY_ENV=dev

# Host path for OpenObserve data (outside deploy bundle; survives redeploys)
OPENOBSERVE_DATA_DIR=/apps/monitoring/data
