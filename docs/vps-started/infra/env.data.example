# Copy to /apps/.env.data on a combined (dev + prod) VPS.
# Replace CHANGE_ME with: openssl rand -hex 24
# Then: sudo chown $USER:$USER /apps/.env.data && chmod 600 /apps/.env.data

POSTGRES_DEV_PASSWORD=CHANGE_ME
POSTGRES_PROD_PASSWORD=CHANGE_ME
REDIS_DEV_PASSWORD=CHANGE_ME
REDIS_PROD_PASSWORD=CHANGE_ME
